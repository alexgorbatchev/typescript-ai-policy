{
  "name": "@alexgorbatchev/typescript-ai-policy",
  "version": "5.0.1",
  "description": "Shared TypeScript AI policy configs and Oxlint rules",
  "homepage": "https://github.com/alexgorbatchev/typescript-ai-policy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexgorbatchev/typescript-ai-policy.git"
  },
  "bugs": {
    "url": "https://github.com/alexgorbatchev/typescript-ai-policy/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "typescript-ai-policy-fix-semantic": "./dist/bin/typescript-ai-policy-fix-semantic.js"
  },
  "exports": {
    "./oxfmt-config": {
      "types": "./dist/oxfmt-config.d.ts",
      "import": "./dist/oxfmt-config.js"
    },
    "./oxlint-config": {
      "types": "./dist/oxlint-config.d.ts",
      "import": "./dist/oxlint-config.js"
    },
    "./oxlint-plugin": {
      "types": "./dist/oxlint-plugin.d.ts",
      "import": "./dist/oxlint-plugin.js"
    }
  },
  "peerDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260330.1",
    "typescript": "^6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0"
  },
  "peerDependenciesMeta": {
    "@typescript/native-preview": {
      "optional": true
    },
    "typescript": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsdown",
    "check": "./scripts/check.sh",
    "fix:semantic": "bun src/semantic-fixes/runApplySemanticFixes.ts",
    "lint:target": "./scripts/lint-target.sh",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/rule-tester": "^8.58.0",
    "@typescript/native-preview": "^7.0.0-dev.20260330.1",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.21.9",
    "typescript": "^6"
  }
}
